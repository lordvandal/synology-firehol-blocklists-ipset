{
  "extends": [
    "config:recommended",
    ":dependencyDashboard"
  ],
  "platformAutomerge": true,
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "ignoreTests": true,
      "automerge": true
    }
  ],
  "rollbackPrs": true,
  "forkProcessing": "enabled"
}
